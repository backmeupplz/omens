PORT=3000
# REQUIRED for Omens itself — generate DIFFERENT values for each: openssl rand -hex 32
JWT_SECRET=
ENCRYPTION_KEY=
SINGLE_USER_MODE=false
POLL_INTERVAL_MINUTES=5
# Optional demo feed user email already present in the Omens DB
DEMO_USER_EMAIL=

# Required when serving the web app from another origin. Example: https://omens.example.com
CORS_ORIGIN=

# Optional Caddy HTTPS reverse proxy.
# Get/set this from your DNS provider by pointing an A/AAAA record at your server.
# If DOMAIN is blank, deploy-prod.sh skips Caddy and Omens stays on http://SERVER_IP:${PORT}
DOMAIN=

# Optional Grafana stack.
# Set all three values below to enable it; leave them blank to keep Grafana off.
# GRAFANA_DOMAIN should be a DNS record such as dash.omens.example.com pointed to the same server.
GRAFANA_DOMAIN=

# PostgreSQL
# REQUIRED for Docker deployment. Choose a strong random password.
POSTGRES_PASSWORD=omens

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_DB_PASSWORD=
GRAFANA_SHARED_DASHBOARD_UID=omens-public-share
GRAFANA_SHARED_DASHBOARD_ACCESS_TOKEN=9f8e7d6c5b4a39281716151413121110
