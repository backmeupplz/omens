# Server
PORT=3000

# Bare-metal/local app runtime only.
# If you run Omens through docker/docker-compose.prod.yml, Docker builds DATABASE_URL for you.
DATABASE_URL=postgres://omens:omens@localhost:5432/omens

# Auth — CHANGE THESE to random strings in production
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string
ENCRYPTION_KEY=change-me-to-a-different-random-string

# Multi-user mode (set to true for single-user self-hosting)
SINGLE_USER_MODE=false

# Source polling interval
POLL_INTERVAL_MINUTES=5

# Required only when the frontend is served from a different origin than the API.
# Example: https://omens.example.com
CORS_ORIGIN=

# Optional demo feed for logged-out visitors
DEMO_USER_EMAIL=n@bdut.ch
